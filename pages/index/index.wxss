.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 80rpx 60rpx 60rpx;
  background: linear-gradient(180deg, #0d0d1a 0%, #1a1a2e 50%, #16213e 100%);
}

.hero {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 60rpx;
}

.trophy {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.08); }
}

.year {
  font-size: 36rpx;
  color: #e8b86d;
  letter-spacing: 8rpx;
  font-weight: 300;
  margin-bottom: 8rpx;
}

.title {
  font-size: 72rpx;
  font-weight: 900;
  color: #fff;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 48rpx;
  font-weight: 700;
  color: #e8b86d;
  letter-spacing: 8rpx;
  margin-bottom: 48rpx;
}

.divider {
  width: 80rpx;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, #e8b86d, transparent);
  margin-bottom: 48rpx;
}

.desc {
  font-size: 30rpx;
  color: rgba(255,255,255,0.6);
  margin-bottom: 40rpx;
}

.stars-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.star-tag {
  padding: 10rpx 24rpx;
  border: 1rpx solid rgba(232,184,109,0.4);
  border-radius: 40rpx;
  font-size: 24rpx;
  color: rgba(232,184,109,0.8);
}

.footer {
  padding-top: 60rpx;
}

.btn-start {
  width: 100%;
  padding: 32rpx 0;
  background: linear-gradient(135deg, #e8b86d, #c9a227);
  color: #1a1a2e;
  font-size: 36rpx;
  font-weight: 800;
  border-radius: 60rpx;
  text-align: center;
  letter-spacing: 4rpx;
  border: none;
  box-shadow: 0 8rpx 32rpx rgba(232,184,109,0.4);
}

.hint {
  text-align: center;
  font-size: 24rpx;
  color: rgba(255,255,255,0.35);
  margin-top: 24rpx;
}
