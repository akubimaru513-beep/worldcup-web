.ad-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 100rpx 60rpx 80rpx;
  background: linear-gradient(180deg, #0d0d1a 0%, #1a1a2e 100%);
}

.loading-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}

.soccer-ball {
  font-size: 120rpx;
  animation: spin 3s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  text-align: center;
}

.loading-dots {
  display: flex;
  gap: 16rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #e8b86d;
  animation: bounce 1.2s ease-in-out infinite;
}

.dot1 { animation-delay: 0s; }
.dot2 { animation-delay: 0.2s; }
.dot3 { animation-delay: 0.4s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

.loading-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.45);
}

.ad-wrap {
  width: 100%;
}

.btn-wrap {
  width: 100%;
}

.btn-continue {
  width: 100%;
  padding: 30rpx 0;
  border-radius: 60rpx;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  border: none;
  transition: all 0.3s;
}

.btn-continue.active {
  background: linear-gradient(135deg, #e8b86d, #c9a227);
  color: #1a1a2e;
  box-shadow: 0 8rpx 32rpx rgba(232,184,109,0.4);
}

.btn-continue.disabled {
  background: rgba(255,255,255,0.1);
  color: rgba(255,255,255,0.4);
}
